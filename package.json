{
  "name": "nexus-pascal",
  "displayName": "Nexus Pascal",
  "description": "Nexus Pascal IDE support for Free Pascal and Lazarus projects.",
  "version": "1.2.7",
  "engines": {
    "vscode": "^1.89.0"
  },
  "extensionDependencies": [
    "ms-vscode.cpptools"
  ],
  "icon": "images/logo.png",
  "categories": [
    "Programming Languages"
  ],
  "publisher": "nxrp-dev",
  "author": "nxrp-dev",
  "license": "MIT",
  "keywords": [
    "free",
    "pascal",
    "freepascal",
    "fpc",
    "lazarus",
    "objectpascal",
    "delphi"
  ],
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/nxrp-dev/nexus-pascal.git"
  },
  "bugs": {
    "url": "https://github.com/nxrp-dev/nexus-pascal/issues"
  },
  "activationEvents": [
    "onDebug"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "objectpascal",
        "aliases": [
          "Object-Pascal"
        ],
        "extensions": [
          ".pas",
          ".pp",
          ".lpr",
          ".inc",
          ".p",
          ".dfm",
          ".fmx",
          ".dpr",
          ".dpk",
          ".lfm",
          ".dpr",
          ".lpr"
        ],
        "configuration": "./pascal-configuration.json"
      },
      {
        "id": "pascal",
        "configuration": "./pascal-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "objectpascal",
        "scopeName": "source.pascal",
        "path": "./syntaxes/fpc.tmLanguage"
      },
      {
        "language": "pascal",
        "scopeName": "source.pascal",
        "path": "./syntaxes/fpc.tmLanguage"
      }
    ],
    "snippets": [
      {
        "language": "objectpascal",
        "path": "./snippets/pascal.json"
      },
      {
        "language": "pascal",
        "path": "./snippets/pascal.json"
      }
    ],
    "commands": [
      {
        "command": "nexusPascal.project.newproject",
        "title": "%project.newproject%",
        "icon": "$(add)"
      },
      {
        "command": "nexusPascal.project.build",
        "title": "%project.build%",
        "icon": "$(play)"
      },
      {
        "command": "nexusPascal.project.rebuild",
        "title": "%project.rebuild%"
      },
      {
        "command": "nexusPascal.project.opensetting",
        "title": "%project.open%"
      },
      {
        "command": "nexusPascal.project.add",
        "title": "%project.newconfig%"
      },
      {
        "command": "nexusPascal.project.setdefault",
        "title": "%project.setdefault%"
      },
      {
        "command": "nexusPascal.lazarus.convertToFpc",
        "title": "Convert to FPC Project",
        "category": "Nexus Pascal"
      },
      {
        "command": "nexusPascal.project.openWithLazarus",
        "title": "Open with Lazarus",
        "icon": "$(link-external)"
      },
      {
        "command": "nexusPascal.project.newfromtemplate",
        "title": "%project.newfromtemplate%",
        "icon": "$(file-add)"
      },
      {
        "command": "nexusPascal.project.inittemplatedir",
        "title": "%project.inittemplatedir%",
        "icon": "$(folder-library)"
      },
      {
        "command": "nexusPascal.project.inittemplatedirtouser",
        "title": "%project.inittemplatedirtouser%",
        "icon": "$(home)"
      },
      {
        "command": "nexusPascal.project.opentemplatedir",
        "title": "%project.opentemplatedir%",
        "icon": "$(folder-opened)"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+shift+down",
        "command": "editor.action.goToImplementation",
        "when": "editorHasImplementationProvider && editorTextFocus && !isInEmbeddedEditor"
      },
      {
        "key": "ctrl+shift+up",
        "command": "editor.action.goToImplementation",
        "when": "editorHasImplementationProvider && editorTextFocus && !isInEmbeddedEditor"
      },
      {
        "key": "ctrl+shift+c",
        "command": "nexusPascal.code.complete",
        "when": "editorTextFocus && !isInEmbeddedEditor"
      }
    ],
    "taskDefinitions": [
      {
        "type": "fpc",
        "required": [
          "file"
        ],
        "properties": {
          "file": {
            "type": "string",
            "description": "%task.file%"
          },
          "cwd": {
            "type": "string",
            "description": "%task.cwd%"
          },
          "buildOption": {
            "type": "object",
            "properties": {
              "targetOS": {
                "type": "string",
                "description": "%task.buildOption.targetOS%",
                "examples": [
                  "linux",
                  "win32",
                  "win64",
                  "Darwin"
                ]
              },
              "targetCPU": {
                "type": "string",
                "description": "%task.buildOption.targetCPU%",
                "examples": [
                  "x86_64",
                  "aarch64",
                  "i386"
                ]
              },
              "searchPath": {
                "type": "array",
                "description": "%task.buildOption.searchPath%",
                "items": {
                  "type": "string"
                }
              },
              "libPath": {
                "type": "array",
                "description": "%task.buildOption.libPath%",
                "items": {
                  "type": "string"
                }
              },
              "unitOutputDir": {
                "type": "string",
                "description": "%task.buildOption.unitOutputDir%"
              },
              "outputFile": {
                "type": "string",
                "description": "%task.buildOption.outputFile%"
              },
              "syntaxMode": {
                "type": "string",
                "description": "%task.buildOption.syntaxMode%",
                "default": "ObjFPC",
                "examples": [
                  "fpc",
                  "Delphi",
                  "DelphiUnicode",
                  "ObjFPC"
                ]
              },
              "optimizationLevel": {
                "type": "number",
                "description": "%task.buildOption.optimizationLevel%",
                "enum": [
                  0,
                  1,
                  2,
                  3,
                  4
                ]
              },
              "forceRebuild": {
                "type": "boolean",
                "description": "%task.buildOption.forceRebuild%",
                "default": false
              },
              "msgIgnore": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "description": "%task.buildOption.msgIgnore%"
              }
            }
          }
        }
      },
      {
        "type": "lazarus",
        "required": [
          "project"
        ],
        "properties": {
          "project": {
            "type": "string",
            "description": "Lazarus project or package file (.lpi or .lpk)"
          },
          "cwd": {
            "type": "string",
            "description": "%task.cwd%"
          },
          "buildMode": {
            "type": "string",
            "description": "Lazarus build mode to pass to lazbuild"
          },
          "forceRebuild": {
            "type": "boolean",
            "description": "Build all project/package files with lazbuild",
            "default": false
          }
        }
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "nexusPascal.project.build",
          "when": "view == FpcProjectExplorer && (viewItem==fpcbuild || viewItem==lazarusbuildmode)",
          "group": "fpcproject@1"
        },
        {
          "command": "nexusPascal.project.rebuild",
          "when": "view == FpcProjectExplorer && (viewItem==fpcbuild || viewItem==lazarusbuildmode)",
          "group": "fpcproject@2"
        },
        {
          "command": "nexusPascal.project.setdefault",
          "when": "view == FpcProjectExplorer && (viewItem==fpcbuild || viewItem==lazarusbuildmode)",
          "group": "fpcprojectcfg@4"
        },
        {
          "command": "nexusPascal.project.add",
          "when": "view == FpcProjectExplorer && (viewItem==fpcproject)",
          "group": "fpcproject@0"
        },
        {
          "command": "nexusPascal.project.openWithLazarus",
          "when": "view == FpcProjectExplorer && viewItem==lazarusproject",
          "group": "lazarusproject@1"
        },
        {
          "command": "nexusPascal.project.build",
          "when": "view == FpcProjectExplorer && (viewItem==fpcbuild || viewItem==lazarusbuildmode)",
          "group": "inline"
        },
        {
          "command": "nexusPascal.lazarus.convertToFpc",
          "when": "view == FpcProjectExplorer && viewItem == lazarusbuildmode",
          "group": "fpcprojectcfg@5"
        }
      ],
      "view/title": [
        {
          "command": "nexusPascal.project.newproject",
          "when": "view == FpcProjectExplorer",
          "group": "navigation",
          "icon": "$(add)"
        },
        {
          "command": "nexusPascal.project.opentemplatedir",
          "when": "view == FpcProjectExplorer",
          "group": "navigation@1"
        },
        {
          "command": "nexusPascal.project.inittemplatedir",
          "when": "view == FpcProjectExplorer",
          "group": "1_template"
        },
        {
          "command": "nexusPascal.project.inittemplatedirtouser",
          "when": "view == FpcProjectExplorer",
          "group": "2_template"
        }
      ]
    },
    "configuration": [
      {
        "title": "Nexus Pascal",
        "properties": {
          "nexusPascal.env.PP": {
            "type": "string",
            "markdownDescription": "%config.env.PP%"
          },
          "nexusPascal.env.LAZARUSDIR": {
            "type": "string",
            "markdownDescription": "%config.env.LAZARUSDIR%"
          },
          "nexusPascal.env.FPCTARGET": {
            "type": "string",
            "markdownDescription": "%config.env.FPCTARGET%",
            "examples": [
              "linux",
              "win32",
              "win64",
              "Darwin"
            ]
          },
          "nexusPascal.env.FPCTARGETCPU": {
            "type": "string",
            "markdownDescription": "%config.env.FPCTARGETCPU%",
            "examples": [
              "x86_64",
              "aarch64",
              "i386"
            ]
          },
          "nexusPascal.format.tabsize": {
            "type": "number",
            "default": 2,
            "markdownDescription": "%config.format.tabsize%"
          },
          "nexusPascal.pasls.path": {
            "type": "string",
            "description": "%config.pasls.path%"
          },
          "nexusPascal.languageServer.FPCSourceDirectory": {
            "type": "string",
            "markdownDescription": "%config.languageServer.FPCSourceDirectory%"
          },
          "nexusPascal.format.enabled": {
            "type": "boolean",
            "default": "true",
            "description": "%config.format.enabled%"
          },
          "nexusPascal.format.cfgpath": {
            "type": "string",
            "description": "%config.format.cfgpath%"
          },
          "nexusPascal.debug.autoBuild": {
            "type": "boolean",
            "default": true,
            "description": "%config.debug.autoBuild%"
          },
          "nexusPascal.project.templateDirectories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "%config.project.templateDirectories%"
          }
        }
      },
      {
        "title": "Nexus Pascal LanguageServer",
        "properties": {
          "nexusPascal.lsp.trace.server": {
            "scope": "window",
            "type": "string",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "off",
            "description": "%lsp.trace.server%"
          },
          "nexusPascal.lsp.initializationOptions.program": {
            "type": "string",
            "description": "%lsp.initializationOptions.program%"
          },
          "nexusPascal.lsp.initializationOptions.overloadPolicy": {
            "type": "number",
            "scope": "application",
            "default": 3,
            "enum": [
              1,
              2,
              3
            ],
            "enumDescriptions": [
              "%lsp.enum.overloadPolicy_1%",
              "%lsp.enum.overloadPolicy_2%",
              "%lsp.enum.overloadPolicy_3%"
            ],
            "description": "%lsp.initializationOptions.overloadPolicy%"
          },
          "nexusPascal.lsp.initializationOptions.maximumCompletions": {
            "type": "number",
            "default": 50,
            "markdownDescription": "%lsp.initializationOptions.maximumCompletions%"
          },
          "nexusPascal.lsp.initializationOptions.insertCompletionsAsSnippets": {
            "type": "boolean",
            "default": false,
            "description": "%lsp.initializationOptions.insertCompletionsAsSnippets%"
          },
          "nexusPascal.lsp.initializationOptions.insertCompletionProcedureBrackets": {
            "type": "boolean",
            "default": false,
            "description": "%lsp.initializationOptions.insertCompletionProcedureBrackets%"
          },
          "nexusPascal.lsp.initializationOptions.includeWorkspaceFoldersAsUnitPaths": {
            "type": "boolean",
            "default": true,
            "description": "%lsp.initializationOptions.includeWorkspaceFoldersAsUnitPaths%"
          },
          "nexusPascal.lsp.initializationOptions.includeWorkspaceFoldersAsIncludePaths": {
            "type": "boolean",
            "default": true,
            "description": "%lsp.initializationOptions.includeWorkspaceFoldersAsIncludePaths%"
          },
          "nexusPascal.lsp.initializationOptions.checkSyntax": {
            "type": "boolean",
            "scope": "application",
            "default": false,
            "description": "%lsp.initializationOptions.checkSyntax%"
          },
          "nexusPascal.lsp.initializationOptions.publishDiagnostics": {
            "type": "boolean",
            "scope": "application",
            "default": false,
            "description": "%lsp.initializationOptions.publishDiagnostics%"
          },
          "nexusPascal.lsp.initializationOptions.workspaceSymbols": {
            "type": "boolean",
            "default": false,
            "description": "%lsp.initializationOptions.workspaceSymbols%"
          },
          "nexusPascal.lsp.initializationOptions.documentSymbols": {
            "type": "boolean",
            "default": true,
            "description": "%lsp.initializationOptions.documentSymbols%"
          },
          "nexusPascal.lsp.initializationOptions.minimalisticCompletions": {
            "type": "boolean",
            "default": false,
            "description": "%lsp.initializationOptions.minimalisticCompletions%"
          },
          "nexusPascal.lsp.initializationOptions.showSyntaxErrors": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%lsp.initializationOptions.showSyntaxErrors%"
          }
        }
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "FpcProjectExplorer",
          "name": "Pascal Projects",
          "icon": "images/logo.png"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "FpcProjectExplorer",
        "contents": "%views.welcome%",
        "when": "!workspace.workspaceFolders"
      }
    ],
    "problemMatchers": [
      {
        "name": "fpc",
        "owner": "external",
        "pattern": [
          {
            "regexp": "Compiling ([^\\s].*(p|pp|pas|lpr|dpr|inc))$",
            "file": 1
          },
          {
            "regexp": "^([\\w]+\\.(p|pp|pas|lpr|dpr|inc))\\((\\d+)\\,(\\d+)\\)\\s(Fatal|Error|Warning|Note):(.*)",
            "line": 3,
            "column": 4,
            "severity": 5,
            "message": 6,
            "loop": true
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "vscode:prepublish": "npm run compile && npm run build-base -- --minify",
    "esbuild": "npm run compile && npm run build-base -- --sourcemap",
    "build-base": "esbuild ./out/extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "vscode-languageclient": "^8.0.1"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.89.0",
    "esbuild": "^0.27.2",
    "glob": "^7.2.0",
    "typescript": "^5.8.3"
  },
  "homepage": "https://github.com/nxrp-dev/nexus-pascal#readme"
}
